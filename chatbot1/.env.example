# RAG Chatbot Configuration
# Copy this file to .env and fill in your actual values
# Do NOT commit .env to git (it's in .gitignore)

# ============================================================================
# REQUIRED: Chroma Cloud
# ============================================================================

CHROMA_HOST=api.trychroma.com
CHROMA_API_KEY=your_chroma_api_key
CHROMA_TENANT=your_tenant_uuid
CHROMA_DATABASE=chatbot1
# ============================================================================
# LLM Backend: "gemini" (cloud) or "ollama" (local)
# ============================================================================

LLM_BACKEND=gemini

# ============================================================================
# REQUIRED if LLM_BACKEND=gemini: Google Gemini API
# ============================================================================

# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_api_key_here

# Gemini model to use
# Options: gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash
GEMINI_MODEL=gemini-2.0-flash

# ============================================================================
# REQUIRED if LLM_BACKEND=ollama: Ollama local
# ============================================================================

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=dolphin-phi:2.7b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# ============================================================================
# OPTIONAL: RAG Tuning
# ============================================================================

# Number of context documents to retrieve
RAG_TOP_K=5

# Minimum cosine similarity score for results (0.0-1.0)
# Lower = more results, Higher = more selective
RAG_SCORE_THRESHOLD=0.3

# ============================================================================
# OPTIONAL: Generation Settings
# ============================================================================

# Maximum tokens in response
MAX_TOKENS=512

# Temperature (0.0-2.0): 0=deterministic, 1=balanced, 2=very creative
TEMPERATURE=0.7
