# ─── nu-finance RAG stack ──────────────────────────────────────────────────

# Zilliz Cloud (fill in your cluster details)
ZILLIZ_CLOUD_URI=https://your-cluster.serverless.aws-region.cloud.zilliz.com
ZILLIZ_API_KEY=your-zilliz-api-key
ZILLIZ_COLLECTION=Nu-Fin1

# LlamaIndex / LlamaParse
LLAMA_CLOUD_API_KEY=your-llama-cloud-api-key

# LLM selection — "gemini" | "mistral"
LLM_PROVIDER=gemini

# Voyage AI Rerank
VOYAGE_API_KEY=your-voyage-api-key
# VOYAGE_RERANK_MODEL=rerank-2.5

# RAG tuning
RAG_TOP_K=10
RAG_RERANK_TOP_N=5

# ─── Gemini ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# ─── Mistral (swap-in) ───────────────────────────────────────────────────────
# MISTRAL_API_KEY=<your-mistral-api-key>
# MISTRAL_MODEL=mistral-small-latest

# ─── RAG Tuning (shared) ─────────────────────────────────────────────────────
RAG_SCORE_THRESHOLD=0.3
MAX_TOKENS=1024
TEMPERATURE=0.7
