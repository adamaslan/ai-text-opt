#!/usr/bin/env python3
"""CLI wrapper to fetch ETF holdings from Yahoo Finance.

Pure terminal/CLI — no browser dependency. Uses httpx for async fetches.

Usage:
    scrape-holdings IGV                                    # stdout table
    scrape-holdings IGV --limit 4                         # top 4 holdings
    scrape-holdings IGV --limit 4 --output igv.csv        # CSV output
    scrape-holdings IGV --format json                     # JSON to stdout
    scrape-holdings IGV --output holdings.csv --append    # append to CSV
"""
import argparse
import asyncio
import csv
import json
import logging
import sys
from pathlib import Path

# Add backend to path for imports
backend_path = Path(__file__).parent.parent.parent / "backend"
sys.path.insert(0, str(backend_path))

from gen_etf_holdings_doc import fetch_top_holdings, Holding
import httpx


def format_as_table(holdings: list[Holding]) -> str:
    """Format holdings as ASCII table."""
    if not holdings:
        return "(no holdings)"

    lines = []
    lines.append("Symbol  Name                          Weight")
    lines.append("------  ----------------------------  -------")
    for h in holdings:
        lines.append(f"{h.symbol:<6}  {h.name[:28]:<28}  {h.weight*100:>6.2f}%")

    return "\n".join(lines)


def format_as_csv(holdings: list[Holding]) -> list[dict]:
    """Format holdings as CSV row dicts."""
    return [
        {
            "etf": h.etf,
            "symbol": h.symbol,
            "name": h.name,
            "weight": f"{h.weight:.4f}",
        }
        for h in holdings
    ]


async def main() -> None:
    parser = argparse.ArgumentParser(
        description="Fetch ETF holdings from Yahoo Finance",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "ticker",
        help="ETF ticker symbol (e.g. IGV, SOXX)",
    )
    parser.add_argument(
        "--limit",
        type=int,
        default=10,
        help="Number of top holdings to fetch (default 10)",
    )
    parser.add_argument(
        "--output",
        type=str,
        help="CSV output file path. Omit for stdout table.",
    )
    parser.add_argument(
        "--format",
        choices=["table", "csv", "json"],
        default="table",
        help="Output format: table (default), csv, or json",
    )
    parser.add_argument(
        "--append",
        action="store_true",
        help="Append to existing CSV instead of overwriting",
    )
    parser.add_argument(
        "--debug",
        action="store_true",
        help="Enable debug logging",
    )

    args = parser.parse_args()

    if args.debug:
        logging.basicConfig(level=logging.DEBUG)
    else:
        logging.basicConfig(level=logging.INFO)

    ticker = args.ticker.upper()

    async with httpx.AsyncClient() as client:
        holdings = await fetch_top_holdings(client, ticker, limit=args.limit)

    if not holdings:
        print(f"✗ Failed to fetch holdings for {ticker}", file=sys.stderr)
        sys.exit(1)

    # Output logic
    if args.output:
        csv_rows = format_as_csv(holdings)
        output_path = Path(args.output)

        # Check if file exists for append mode
        file_exists = output_path.exists()

        with output_path.open("a" if (args.append and file_exists) else "w", newline="") as f:
            fieldnames = ["etf", "symbol", "name", "weight"]
            writer = csv.DictWriter(f, fieldnames=fieldnames)

            # Write header only if new file or not appending
            if not file_exists or not args.append:
                writer.writeheader()

            writer.writerows(csv_rows)

        print(f"✓ Written {len(csv_rows)} holdings to {output_path}")

    else:
        if args.format == "json":
            output = [
                {"etf": h.etf, "symbol": h.symbol, "name": h.name, "weight": h.weight}
                for h in holdings
            ]
            print(json.dumps(output, indent=2))
        else:  # table format (default)
            print(format_as_table(holdings))


if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        print("\n✗ Interrupted", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"✗ Error: {e}", file=sys.stderr)
        sys.exit(1)
